<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MallMate</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" crossorigin="anonymous"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --red: #FF2D55;
      --red-dim: rgba(255,45,85,0.15);
      --bg: #0a0a0a;
      --surface: #1a1a1a;
      --border: #2a2a2a;
      --text: #ffffff;
      --muted: #888888;
      --success: #22c55e;
      --success-dim: rgba(34,197,94,0.15);
    }

    html, body { height: 100%; background: #060606; font-family: 'Outfit', sans-serif; color: var(--text); }

    /* ── Layout ── */
    #root {
      min-height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 16px;
    }

    .phone-shell {
      width: 390px;
      height: 844px;
      background: var(--bg);
      border-radius: 52px;
      border: 12px solid #1c1c1e;
      box-shadow: 0 32px 80px rgba(0,0,0,0.9), inset 0 0 0 1px #2c2c2e;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* notch */
    .phone-shell::before {
      content: '';
      position: absolute;
      top: 0; left: 50%;
      transform: translateX(-50%);
      width: 126px; height: 34px;
      background: #1c1c1e;
      border-radius: 0 0 24px 24px;
      z-index: 20;
    }

    .screen-wrap {
      flex: 1;
      overflow: hidden;
      position: relative;
    }

    /* ── Screen transitions ── */
    .screen-enter {
      animation: slideIn 0.3s cubic-bezier(0.4,0,0.2,1) forwards;
    }
    .screen-exit {
      animation: slideOut 0.3s cubic-bezier(0.4,0,0.2,1) forwards;
    }
    .screen-enter-back {
      animation: slideInBack 0.3s cubic-bezier(0.4,0,0.2,1) forwards;
    }

    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0.6; }
      to   { transform: translateX(0);    opacity: 1; }
    }
    @keyframes slideOut {
      from { transform: translateX(0);     opacity: 1; }
      to   { transform: translateX(-30%);  opacity: 0; }
    }
    @keyframes slideInBack {
      from { transform: translateX(-30%); opacity: 0; }
      to   { transform: translateX(0);    opacity: 1; }
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.97); }
      to   { opacity: 1; transform: scale(1); }
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-10px); }
    }
    @keyframes pulse {
      0%,100% { box-shadow: 0 0 0 0 rgba(255,45,85,0.4); }
      50%      { box-shadow: 0 0 0 12px rgba(255,45,85,0); }
    }
    @keyframes checkPop {
      0%   { transform: scale(0); opacity: 0; }
      70%  { transform: scale(1.2); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }

    /* ── Screen base ── */
    .screen {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      padding: 52px 24px 32px;
      background: linear-gradient(160deg, #0f0f0f 0%, #0a0a0a 100%);
      overflow-y: auto;
      scrollbar-width: none;
    }
    .screen::-webkit-scrollbar { display: none; }

    /* ── Typography ── */
    .title { font-size: 34px; font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; margin-bottom: 10px; }
    .subtitle { font-size: 16px; color: var(--muted); line-height: 1.55; }
    .screen-title { font-size: 22px; font-weight: 700; }
    .label { font-size: 13px; color: var(--muted); margin-bottom: 8px; display: block; }

    /* ── Buttons ── */
    .btn {
      width: 100%; padding: 16px; border-radius: 14px; border: none;
      font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600;
      cursor: pointer; transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-primary { background: var(--red); color: #fff; }
    .btn-primary:hover:not(:disabled) { background: #ff1144; transform: translateY(-2px); box-shadow: 0 10px 24px rgba(255,45,85,0.4); }
    .btn-primary:active:not(:disabled) { transform: translateY(0); box-shadow: none; }
    .btn-primary:disabled { background: #2a2a2a; color: #555; cursor: not-allowed; }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover:not(:disabled) { background: rgba(255,255,255,0.04); border-color: #444; }
    .btn-danger { background: transparent; color: var(--red); border: 1px solid rgba(255,45,85,0.4); }
    .btn-danger:hover { background: var(--red-dim); }

    /* ── Input ── */
    .input-wrap { margin-bottom: 16px; }
    .input {
      width: 100%; padding: 15px 16px;
      background: #141414; border: 1px solid var(--border); border-radius: 12px;
      color: var(--text); font-family: 'Outfit', sans-serif; font-size: 16px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input:focus { outline: none; border-color: var(--red); background: #1a1a1a; box-shadow: 0 0 0 3px rgba(255,45,85,0.12); }
    .input::placeholder { color: #444; }
    .input.error { border-color: var(--red); }

    /* ── Phone flag prefix ── */
    .phone-row { display: flex; gap: 10px; }
    .phone-prefix {
      padding: 15px 14px; background: #141414; border: 1px solid var(--border);
      border-radius: 12px; font-size: 16px; color: var(--text); white-space: nowrap;
      display: flex; align-items: center; gap: 6px; font-weight: 500;
    }

    /* ── OTP boxes ── */
    .otp-row { display: flex; gap: 10px; justify-content: center; margin: 24px 0; }
    .otp-box {
      width: 46px; height: 56px; background: #141414; border: 2px solid var(--border);
      border-radius: 12px; text-align: center; font-size: 22px; font-weight: 700;
      color: var(--text); font-family: 'Outfit', sans-serif;
      transition: border-color 0.2s;
    }
    .otp-box:focus { outline: none; border-color: var(--red); background: #1a1a1a; }
    .otp-box.filled { border-color: var(--red); }

    /* ── Alert boxes ── */
    .alert { border-radius: 12px; padding: 13px 16px; margin-bottom: 16px; display: flex; gap: 10px; align-items: flex-start; }
    .alert-success { background: var(--success-dim); border: 1px solid rgba(34,197,94,0.3); }
    .alert-success p { color: var(--success); font-size: 14px; }
    .alert-error { background: var(--red-dim); border: 1px solid rgba(255,45,85,0.4); }
    .alert-error p { color: var(--red); font-size: 14px; }
    .alert-info { background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.3); }
    .alert-info p { color: #818cf8; font-size: 14px; }

    /* ── Nav bar ── */
    .nav-bar {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 24px;
    }
    .nav-back {
      width: 36px; height: 36px; background: rgba(255,255,255,0.06); border: none;
      border-radius: 10px; color: var(--text); font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .nav-back:hover { background: rgba(255,255,255,0.1); }
    .nav-spacer { width: 36px; }

    /* ── Lang toggle ── */
    .lang-row {
      position: absolute; top: 42px; right: 20px; z-index: 10;
      display: flex; gap: 4px;
    }
    .lang-btn {
      padding: 4px 10px; background: #222; border: none; border-radius: 7px;
      font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 600;
      color: var(--muted); cursor: pointer; transition: all 0.15s;
    }
    .lang-btn.active { background: var(--red); color: #fff; }

    /* ── Mall card ── */
    .mall-card {
      background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      border-radius: 18px; padding: 16px; cursor: pointer;
      transition: transform 0.2s, border-color 0.2s, background 0.2s;
      display: flex; gap: 14px; align-items: flex-start;
    }
    .mall-card:hover { transform: translateY(-2px); border-color: #444; background: rgba(255,255,255,0.07); }
    .mall-card.featured { background: rgba(255,45,85,0.1); border-color: rgba(255,45,85,0.5); }
    .mall-icon {
      width: 56px; height: 56px; background: var(--red-dim); border-radius: 14px;
      display: flex; align-items: center; justify-content: center; font-size: 26px; flex-shrink: 0;
    }
    .mall-info h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
    .mall-info p { font-size: 13px; color: var(--muted); margin: 2px 0; }
    .badge {
      display: inline-block; padding: 2px 8px; background: rgba(255,45,85,0.2);
      border-radius: 20px; font-size: 11px; font-weight: 600; color: var(--red);
      margin-top: 6px;
    }

    /* ── Feature cards ── */
    .feature-card {
      background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      border-radius: 16px; padding: 16px; display: flex; gap: 14px; align-items: flex-start;
    }
    .feature-icon {
      width: 44px; height: 44px; background: var(--red-dim); border-radius: 12px;
      display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .feature-card h4 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
    .feature-card p { font-size: 13px; color: var(--muted); }

    /* ── Store item ── */
    .store-item {
      background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      border-radius: 14px; padding: 14px; display: flex; gap: 12px; align-items: center;
      cursor: pointer; transition: background 0.15s;
    }
    .store-item:hover { background: rgba(255,255,255,0.07); }
    .store-icon {
      width: 44px; height: 44px; background: var(--red-dim); border-radius: 10px;
      display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .store-detail h4 { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
    .store-detail p { font-size: 12px; color: var(--muted); }
    .store-action {
      margin-left: auto; padding: 6px 12px; background: var(--red-dim);
      border: 1px solid rgba(255,45,85,0.3); border-radius: 8px; color: var(--red);
      font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap;
      font-family: 'Outfit', sans-serif; transition: background 0.15s;
    }
    .store-action:hover { background: rgba(255,45,85,0.25); }

    /* ── Map placeholder ── */
    .map-ph {
      width: 100%; height: 180px; background: #111; border: 1px solid var(--border);
      border-radius: 18px; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 8px;
      color: #444; font-size: 13px; position: relative; overflow: hidden;
      margin-bottom: 16px;
    }
    .map-ph::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 40% 50%, rgba(255,45,85,0.08) 0%, transparent 70%);
    }
    .map-ph-icon { font-size: 36px; }

    /* ── Confirmation / parking info ── */
    .confirm-card {
      background: rgba(255,45,85,0.1); border: 1px solid rgba(255,45,85,0.35);
      border-radius: 20px; padding: 24px; text-align: center;
    }
    .confirm-card .big-num { font-size: 52px; font-weight: 700; color: var(--red); line-height: 1; margin: 12px 0; }
    .confirm-card p { color: var(--muted); font-size: 14px; }
    .confirm-card h3 { font-size: 18px; font-weight: 700; }

    /* ── Parking grid ── */
    .parking-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .spot-btn {
      padding: 14px 0; background: #1a1a1a; border: 1.5px solid var(--border);
      border-radius: 10px; color: var(--text); font-weight: 600; font-size: 13px;
      cursor: pointer; transition: all 0.15s; font-family: 'Outfit', sans-serif;
    }
    .spot-btn:hover { background: #222; border-color: #555; }
    .spot-btn.selected { background: var(--red); border-color: var(--red); color: #fff; }
    .spot-btn.occupied { background: #111; border-color: #1a1a1a; color: #333; cursor: not-allowed; }

    /* ── Profile ── */
    .avatar {
      width: 80px; height: 80px; background: var(--red-dim); border-radius: 50%;
      display: flex; align-items: center; justify-content: center; font-size: 38px;
      margin: 0 auto 12px; border: 2px solid rgba(255,45,85,0.3);
      animation: pulse 2.5s ease-in-out infinite;
    }

    /* ── Settings ── */
    .settings-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px; background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      border-radius: 14px; cursor: pointer; transition: background 0.15s;
    }
    .settings-row:hover { background: rgba(255,255,255,0.07); }
    .settings-label { font-size: 15px; font-weight: 500; }
    .settings-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .settings-arrow { color: var(--red); font-size: 18px; }

    .toggle {
      width: 48px; height: 28px; border-radius: 14px; border: none; cursor: pointer;
      transition: background 0.2s; position: relative;
    }
    .toggle::after {
      content: ''; position: absolute; top: 3px; width: 22px; height: 22px;
      background: #fff; border-radius: 50%; transition: left 0.2s; box-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }
    .toggle.off { background: #333; }
    .toggle.off::after { left: 3px; }
    .toggle.on { background: var(--red); }
    .toggle.on::after { left: 23px; }

    /* ── Spinner ── */
    .spinner {
      width: 44px; height: 44px; border: 3px solid #222;
      border-top-color: var(--red); border-radius: 50%;
      animation: spin 0.75s linear infinite;
    }

    /* ── Check animation ── */
    .check-circle {
      width: 88px; height: 88px; background: rgba(34,197,94,0.15); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 44px; margin: 0 auto 24px;
      animation: checkPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    .check-red {
      background: var(--red-dim);
      animation: checkPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    /* ── Divider ── */
    .divider { height: 1px; background: var(--border); margin: 20px 0; }

    /* ── Progress dots ── */
    .progress-dots { display: flex; gap: 6px; justify-content: center; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: #333; transition: all 0.3s; }
    .dot.active { width: 20px; border-radius: 4px; background: var(--red); }

    /* ── Search bar ── */
    .search-bar {
      display: flex; gap: 10px; align-items: center;
      background: #141414; border: 1px solid var(--border); border-radius: 12px;
      padding: 12px 16px;
    }
    .search-bar input {
      background: none; border: none; outline: none; color: var(--text);
      font-family: 'Outfit', sans-serif; font-size: 15px; flex: 1;
    }
    .search-bar input::placeholder { color: #444; }

    /* ── Tab bar (bottom nav) ── */
    .tab-bar {
      display: flex; border-top: 1px solid var(--border);
      background: rgba(10,10,10,0.95); backdrop-filter: blur(20px);
      padding: 10px 0 20px;
    }
    .tab-item {
      flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px;
      background: none; border: none; cursor: pointer; transition: opacity 0.15s;
      font-family: 'Outfit', sans-serif;
    }
    .tab-icon { font-size: 22px; }
    .tab-label { font-size: 10px; font-weight: 500; color: var(--muted); }
    .tab-item.active .tab-label { color: var(--red); }
    .tab-item.active .tab-icon { filter: drop-shadow(0 0 6px rgba(255,45,85,0.5)); }

    /* ── Utility ── */
    .spacer { flex: 1; }
    .stack { display: flex; flex-direction: column; gap: 12px; }
    .row { display: flex; gap: 10px; }
    .center { text-align: center; display: flex; flex-direction: column; align-items: center; }
    .red { color: var(--red); }
    .muted { color: var(--muted); font-size: 14px; }
    .small { font-size: 12px; }

    /* ── Responsive: full-screen on mobile ── */
    @media (max-width: 430px) {
      #root { padding: 0; }
      .phone-shell {
        width: 100%; height: 100vh; border-radius: 0; border: none;
        box-shadow: none;
      }
      #root { justify-content: flex-start; }
    }
  </style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
  const { useState, useEffect, useRef, useCallback } = React;

  /* ─────────── i18n ─────────── */
  const LANG = {
    en: {
      appName: 'MallMate',
      tagline: 'Navigate malls, save parking,\nreserve queues — all in one.',
      getStarted: 'Get Started',
      skip: 'Skip',
      next: 'Next',
      back: 'Back',
      enterPhone: 'Enter Your Phone',
      phoneHint: "We'll send a 6-digit verification code.",
      phone: 'Phone Number',
      sendCode: 'Send Code',
      verifying: 'Sending code…',
      enterCode: 'Check Your SMS',
      codeHint: 'Enter the 6-digit code we sent to',
      verify: 'Verify & Continue',
      resend: 'Resend Code',
      codeSent: 'Code sent! Check your messages.',
      codeError: 'Incorrect code. Please try again.',
      setupProfile: 'Set Up Profile',
      profileHint: 'Personalize your experience.',
      fullName: 'Full Name',
      email: 'Email (optional)',
      namePh: 'John Doe',
      emailPh: 'john@example.com',
      saveProfile: 'Save & Continue',
      enableLocation: 'Enable Location',
      locationDesc: 'Find malls near you and navigate inside with real-time directions.',
      allowLocation: 'Allow Location Access',
      skipLocation: 'Not Now',
      homeTitle: 'Malls Near You',
      locLabel: '📍 Current Location',
      city: 'Bangkok',
      searchPh: 'Search malls, stores…',
      stores: 'stores',
      away: 'km away',
      featured: 'Featured',
      open: 'Open Now',
      mallDetail: 'Mall Detail',
      floorMap: 'Floor Map & Navigation',
      restaurants: 'Restaurants',
      services: 'Services',
      shopping: 'Shopping',
      queueReserve: 'Reserve Queue',
      saveParking: 'Save Parking',
      waitAvg: 'Average wait',
      partiesAhead: 'parties ahead',
      reserveQueue: 'Reserve My Spot',
      queueConfirmed: 'You\'re in the queue!',
      queueNote: 'We\'ll notify you when your turn is near.',
      yourTurnIn: 'Estimated wait',
      minutes: 'min',
      parkingTitle: 'Save Parking Spot',
      pickSpot: 'Tap to select your spot',
      level: 'Level',
      zone: 'Zone',
      confirmSpot: 'Confirm Spot',
      parkingSaved: 'Parking Saved!',
      parkingNote: 'We\'ll navigate you back anytime.',
      navigateBack: 'Navigate to Car',
      explore: 'Continue Exploring',
      yourProfile: 'Your Profile',
      history: 'Visit History',
      favorites: 'Favorites',
      settings: 'Settings',
      notifications: 'Notifications',
      darkMode: 'Dark Mode',
      language: 'Language',
      version: 'Version',
      logout: 'Log Out',
      profileSaved: 'Profile updated!',
      loading: 'Loading…',
      tabs: { home: 'Home', map: 'Map', queues: 'Queues', parking: 'Parking', profile: 'Profile' },
      navFeatures: [
        { icon: '🗺️', title: 'Real-time Navigation', desc: 'Indoor maps for every floor of every mall.' },
        { icon: '🚗', title: 'Parking Memory',       desc: 'Never forget where you parked again.' },
        { icon: '⏰', title: 'Queue Booking',         desc: 'Reserve at any restaurant — skip the line.' },
      ],
    },
    th: {
      appName: 'MallMate',
      tagline: 'นำทางในห้าง บันทึกที่จอดรถ\nจองคิวทุกร้าน ในที่เดียว',
      getStarted: 'เริ่มใช้งาน',
      skip: 'ข้าม',
      next: 'ถัดไป',
      back: 'กลับ',
      enterPhone: 'ระบุเบอร์โทรศัพท์',
      phoneHint: 'เราจะส่งรหัส 6 หลักไปยังเบอร์ของคุณ',
      phone: 'หมายเลขโทรศัพท์',
      sendCode: 'ส่งรหัส',
      verifying: 'กำลังส่งรหัส…',
      enterCode: 'ตรวจสอบ SMS',
      codeHint: 'ระบุรหัส 6 หลักที่ส่งไปยัง',
      verify: 'ยืนยัน & ต่อไป',
      resend: 'ส่งรหัสอีกครั้ง',
      codeSent: 'ส่งรหัสเรียบร้อย! ตรวจสอบ SMS',
      codeError: 'รหัสไม่ถูกต้อง กรุณาลองใหม่',
      setupProfile: 'ตั้งค่าโปรไฟล์',
      profileHint: 'ปรับประสบการณ์ให้เป็นของคุณ',
      fullName: 'ชื่อ-นามสกุล',
      email: 'อีเมล (ไม่บังคับ)',
      namePh: 'สมชาย ใจดี',
      emailPh: 'somchai@example.com',
      saveProfile: 'บันทึก & ต่อไป',
      enableLocation: 'เปิดใช้งานตำแหน่ง',
      locationDesc: 'ค้นหาห้างใกล้เคียงและนำทางภายในด้วยแผนที่แบบ Real-time',
      allowLocation: 'อนุญาตการเข้าถึงตำแหน่ง',
      skipLocation: 'ไม่ใช่ตอนนี้',
      homeTitle: 'ห้างใกล้คุณ',
      locLabel: '📍 ตำแหน่งปัจจุบัน',
      city: 'กรุงเทพฯ',
      searchPh: 'ค้นหาห้าง, ร้านค้า…',
      stores: 'ร้าน',
      away: 'กม.',
      featured: 'แนะนำ',
      open: 'เปิดอยู่',
      mallDetail: 'รายละเอียดห้าง',
      floorMap: 'แผนที่ & นำทาง',
      restaurants: 'ร้านอาหาร',
      services: 'บริการ',
      shopping: 'ช็อปปิ้ง',
      queueReserve: 'จองคิว',
      saveParking: 'บันทึกที่จอดรถ',
      waitAvg: 'รอเฉลี่ย',
      partiesAhead: 'คิวข้างหน้า',
      reserveQueue: 'จองที่นี่',
      queueConfirmed: 'คุณอยู่ในคิวแล้ว!',
      queueNote: 'เราจะแจ้งเตือนเมื่อใกล้ถึงคิวของคุณ',
      yourTurnIn: 'เวลารอโดยประมาณ',
      minutes: 'นาที',
      parkingTitle: 'บันทึกที่จอดรถ',
      pickSpot: 'แตะเพื่อเลือกที่จอดรถ',
      level: 'ชั้น',
      zone: 'โซน',
      confirmSpot: 'ยืนยันที่จอดรถ',
      parkingSaved: 'บันทึกที่จอดรถแล้ว!',
      parkingNote: 'เราจะนำทางคุณกลับมาได้ตลอดเวลา',
      navigateBack: 'นำทางไปที่รถ',
      explore: 'เดินต่อ',
      yourProfile: 'โปรไฟล์ของคุณ',
      history: 'ประวัติการเยี่ยมชม',
      favorites: 'รายการโปรด',
      settings: 'ตั้งค่า',
      notifications: 'การแจ้งเตือน',
      darkMode: 'โหมดมืด',
      language: 'ภาษา',
      version: 'เวอร์ชัน',
      logout: 'ออกจากระบบ',
      profileSaved: 'อัปเดตโปรไฟล์แล้ว!',
      loading: 'กำลังโหลด…',
      tabs: { home: 'หน้าแรก', map: 'แผนที่', queues: 'คิว', parking: 'จอดรถ', profile: 'โปรไฟล์' },
      navFeatures: [
        { icon: '🗺️', title: 'นำทาง Real-time',      desc: 'แผนที่ภายในทุกชั้นของทุกห้าง' },
        { icon: '🚗', title: 'จดจำที่จอดรถ',          desc: 'ไม่ลืมที่จอดรถอีกต่อไป' },
        { icon: '⏰', title: 'จองคิวล่วงหน้า',        desc: 'จองโต๊ะทุกร้านได้เลย ไม่ต้องรอ' },
      ],
    },
  };

  /* ─────────── Data ─────────── */
  const MALLS = [
    { id: 1, icon: '🏢', name: 'Central World',  dist: '2.3', cnt: '500+', featured: true },
    { id: 2, icon: '🏬', name: 'Siam Paragon',   dist: '1.8', cnt: '350+', featured: false },
    { id: 3, icon: '🏘️', name: 'EmQuartier',     dist: '3.1', cnt: '280+', featured: false },
    { id: 4, icon: '🏪', name: 'The Mall Bangkapi', dist: '5.2', cnt: '220+', featured: false },
  ];

  const STORES = [
    { id: 1, icon: '🍽️', name: 'Siam Kitchen', floor: 'L3', wait: 28, type: 'restaurant' },
    { id: 2, icon: '🍜', name: 'Ramen House',  floor: 'L2', wait: 15, type: 'restaurant' },
    { id: 3, icon: '☕', name: 'Café Amazon',   floor: 'G',  wait: 8,  type: 'restaurant' },
    { id: 4, icon: '👗', name: 'Zara',          floor: 'L1', wait: 0,  type: 'shopping' },
    { id: 5, icon: '💊', name: 'Watsons',       floor: 'G',  wait: 0,  type: 'services' },
  ];

  const SPOTS = [
    'A1','A2','A3','A4',
    'B1','B2','B3','B4',
    'C1','C2','C3','C4',
  ];
  const OCCUPIED = ['A2','B3','C1'];

  /* ─────────── Helpers ─────────── */
  function useTransition() {
    const [cls, setCls] = useState('screen-enter');
    const navigate = useCallback((fn, isBack = false) => {
      setCls(isBack ? 'screen-enter-back' : 'screen-enter');
      fn();
    }, []);
    return [cls, navigate];
  }

  /* ─────────── Screens ─────────── */

  function WelcomeScreen({ t, lang, setLang, go }) {
    const [step, setStep] = useState(0);
    const feat = t.navFeatures;
    return (
      <div className="screen" style={{ justifyContent: 'center' }}>
        <LangToggle lang={lang} setLang={setLang} />
        {step === 0 ? (
          <div className="center" style={{ gap: 0 }}>
            <div style={{ fontSize: 72, animation: 'float 3s ease-in-out infinite', marginBottom: 24 }}>🗺️</div>
            <h1 className="title" style={{ textAlign: 'center' }}>{t.appName}</h1>
            <p className="subtitle" style={{ textAlign: 'center', marginBottom: 40, whiteSpace: 'pre-line' }}>{t.tagline}</p>
            <div className="stack" style={{ width: '100%' }}>
              {feat.map((f, i) => (
                <div key={i} className="feature-card">
                  <div className="feature-icon">{f.icon}</div>
                  <div>
                    <h4>{f.title}</h4>
                    <p>{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
            <div style={{ marginTop: 32, width: '100%', display: 'flex', flexDirection: 'column', gap: 12 }}>
              <button className="btn btn-primary" onClick={() => go('phone')}>{t.getStarted}</button>
              <button className="btn btn-ghost" onClick={() => go('home')}>{t.skip}</button>
            </div>
          </div>
        ) : null}
      </div>
    );
  }

  function PhoneScreen({ t, lang, setLang, go }) {
    const [phone, setPhone] = useState('');
    const valid = phone.replace(/\D/g,'').length >= 9;
    function submit() {
      if (!valid) return;
      go('phone-loading', { phone });
    }
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <button className="nav-back" style={{ marginBottom: 28, alignSelf: 'flex-start' }} onClick={() => go('welcome', null, true)}>←</button>
        <div style={{ marginBottom: 32 }}>
          <div className="progress-dots" style={{ justifyContent: 'flex-start', marginBottom: 20 }}>
            {[0,1,2,3].map(i => <div key={i} className={`dot ${i===0?'active':''}`} />)}
          </div>
          <h2 className="title" style={{ fontSize: 28 }}>{t.enterPhone}</h2>
          <p className="subtitle">{t.phoneHint}</p>
        </div>
        <div className="input-wrap">
          <span className="label">{t.phone}</span>
          <div className="phone-row">
            <div className="phone-prefix">🇹🇭 +66</div>
            <input
              className="input" type="tel" placeholder="8X XXX XXXX"
              value={phone} onChange={e => setPhone(e.target.value)}
              onKeyDown={e => e.key === 'Enter' && submit()}
              style={{ flex: 1 }}
            />
          </div>
        </div>
        <div className="spacer" />
        <div className="stack">
          <button className="btn btn-primary" onClick={submit} disabled={!valid}>{t.sendCode}</button>
          <button className="btn btn-ghost" onClick={() => go('home')}>{t.skip}</button>
        </div>
      </div>
    );
  }

  function PhoneLoadingScreen({ t, lang, setLang, go, state }) {
    useEffect(() => {
      const timer = setTimeout(() => go('code', state), 1800);
      return () => clearTimeout(timer);
    }, []);
    return (
      <div className="screen center" style={{ justifyContent: 'center' }}>
        <LangToggle lang={lang} setLang={setLang} />
        <div className="spinner" style={{ marginBottom: 24 }} />
        <p className="subtitle">{t.verifying}</p>
      </div>
    );
  }

  function CodeScreen({ t, lang, setLang, go, state }) {
    const [digits, setDigits] = useState(['','','','','','']);
    const [error, setError] = useState(false);
    const refs = [useRef(),useRef(),useRef(),useRef(),useRef(),useRef()];
    const code = digits.join('');
    const filled = code.length === 6;

    function handleChange(i, val) {
      if (!/^\d?$/.test(val)) return;
      const next = [...digits];
      next[i] = val;
      setDigits(next);
      setError(false);
      if (val && i < 5) refs[i+1].current.focus();
    }
    function handleKey(i, e) {
      if (e.key === 'Backspace' && !digits[i] && i > 0) {
        refs[i-1].current.focus();
      }
    }
    function submit() {
      if (!filled) return;
      if (code === '123456' || true) { // demo: any 6-digit code works
        go('profile', state);
      } else {
        setError(true);
        setDigits(['','','','','','']);
        refs[0].current.focus();
      }
    }
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <button className="nav-back" style={{ marginBottom: 28, alignSelf: 'flex-start' }} onClick={() => go('phone', null, true)}>←</button>
        <div style={{ marginBottom: 16 }}>
          <div className="progress-dots" style={{ justifyContent: 'flex-start', marginBottom: 20 }}>
            {[0,1,2,3].map(i => <div key={i} className={`dot ${i===1?'active':''}`} />)}
          </div>
          <h2 className="title" style={{ fontSize: 28 }}>{t.enterCode}</h2>
          <p className="subtitle">{t.codeHint} <span style={{ color: '#fff' }}>+66 {state?.phone||''}</span></p>
        </div>
        {!error && (
          <div className="alert alert-success">
            <span>✓</span>
            <p>{t.codeSent}</p>
          </div>
        )}
        {error && (
          <div className="alert alert-error">
            <span>✗</span>
            <p>{t.codeError}</p>
          </div>
        )}
        <div className="otp-row">
          {digits.map((d, i) => (
            <input
              key={i} ref={refs[i]} className={`otp-box ${d?'filled':''} ${error?'error':''}`}
              type="text" inputMode="numeric" maxLength={1}
              value={d}
              onChange={e => handleChange(i, e.target.value)}
              onKeyDown={e => handleKey(i, e)}
            />
          ))}
        </div>
        <div className="spacer" />
        <div className="stack">
          <button className="btn btn-primary" onClick={submit} disabled={!filled}>{t.verify}</button>
          <button className="btn btn-ghost" onClick={() => go('phone-loading', state)}>{t.resend}</button>
        </div>
      </div>
    );
  }

  function ProfileScreen({ t, lang, setLang, go, state }) {
    const [name, setName] = useState('');
    const [email, setEmail] = useState('');
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <button className="nav-back" style={{ marginBottom: 28, alignSelf: 'flex-start' }} onClick={() => go('code', state, true)}>←</button>
        <div style={{ marginBottom: 28 }}>
          <div className="progress-dots" style={{ justifyContent: 'flex-start', marginBottom: 20 }}>
            {[0,1,2,3].map(i => <div key={i} className={`dot ${i===2?'active':''}`} />)}
          </div>
          <h2 className="title" style={{ fontSize: 28 }}>{t.setupProfile}</h2>
          <p className="subtitle">{t.profileHint}</p>
        </div>
        <div>
          <div className="input-wrap">
            <span className="label">{t.fullName}</span>
            <input className="input" type="text" placeholder={t.namePh} value={name} onChange={e => setName(e.target.value)} />
          </div>
          <div className="input-wrap">
            <span className="label">{t.email}</span>
            <input className="input" type="email" placeholder={t.emailPh} value={email} onChange={e => setEmail(e.target.value)} />
          </div>
        </div>
        <div className="spacer" />
        <div className="stack">
          <button className="btn btn-primary" onClick={() => go('location', { ...state, name, email })}>{t.saveProfile}</button>
          <button className="btn btn-ghost" onClick={() => go('location', state)}>{t.skip}</button>
        </div>
      </div>
    );
  }

  function LocationScreen({ t, lang, setLang, go, state }) {
    return (
      <div className="screen center" style={{ justifyContent: 'center' }}>
        <LangToggle lang={lang} setLang={setLang} />
        <div style={{ marginBottom: 28 }}>
          <div className="progress-dots" style={{ justifyContent: 'center', marginBottom: 24 }}>
            {[0,1,2,3].map(i => <div key={i} className={`dot ${i===3?'active':''}`} />)}
          </div>
          <div style={{ fontSize: 72, marginBottom: 24, animation: 'float 3s ease-in-out infinite' }}>📍</div>
          <h2 className="title" style={{ textAlign: 'center' }}>{t.enableLocation}</h2>
          <p className="subtitle" style={{ textAlign: 'center', marginTop: 8 }}>{t.locationDesc}</p>
        </div>
        <div className="stack" style={{ width: '100%' }}>
          <button className="btn btn-primary" onClick={() => go('home')}>{t.allowLocation}</button>
          <button className="btn btn-ghost" onClick={() => go('home')}>{t.skipLocation}</button>
        </div>
      </div>
    );
  }

  function HomeScreen({ t, lang, setLang, go }) {
    const [search, setSearch] = useState('');
    const filtered = MALLS.filter(m => m.name.toLowerCase().includes(search.toLowerCase()));
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <div style={{ paddingTop: 8, marginBottom: 20 }}>
          <p style={{ fontSize: 12, color: 'var(--muted)', marginBottom: 4 }}>{t.locLabel}</p>
          <h2 style={{ fontSize: 26, fontWeight: 700 }}>{t.city}</h2>
        </div>
        <div className="search-bar" style={{ marginBottom: 20 }}>
          <span style={{ color: 'var(--muted)' }}>🔍</span>
          <input placeholder={t.searchPh} value={search} onChange={e => setSearch(e.target.value)} />
        </div>
        <div className="stack">
          {filtered.map(m => (
            <div key={m.id} className={`mall-card ${m.featured?'featured':''}`} onClick={() => go('mall-detail', { mall: m })}>
              <div className="mall-icon">{m.icon}</div>
              <div className="mall-info">
                <h3>{m.name}</h3>
                <p>📍 {m.dist} {t.away}</p>
                <p>{m.cnt} {t.stores}</p>
                {m.featured && <span className="badge">{t.featured}</span>}
              </div>
              <span className="settings-arrow">›</span>
            </div>
          ))}
        </div>
        <div className="spacer" />
        <TabBar active="home" t={t} go={go} />
      </div>
    );
  }

  function MallDetailScreen({ t, lang, setLang, go, state }) {
    const mall = state?.mall || MALLS[0];
    const [tab, setTab] = useState('restaurants');
    const storeFilter = { restaurants: 'restaurant', services: 'services', shopping: 'shopping' };
    const shown = STORES.filter(s => s.type === storeFilter[tab] || (tab === 'restaurants' && s.type === 'restaurant'));
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <div className="nav-bar">
          <button className="nav-back" onClick={() => go('home', null, true)}>←</button>
          <span className="screen-title">{mall.name}</span>
          <div className="nav-spacer" />
        </div>
        <div className="map-ph" style={{ marginBottom: 16 }}>
          <span className="map-ph-icon">🗺️</span>
          <span>{t.floorMap}</span>
        </div>
        <p style={{ color: 'var(--muted)', fontSize: 13, marginBottom: 16 }}>
          {mall.cnt} {t.stores} • {mall.dist} {t.away}
        </p>
        <div className="row" style={{ marginBottom: 16 }}>
          {['restaurants','services','shopping'].map(tab2 => (
            <button key={tab2} onClick={() => setTab(tab2)} style={{
              padding: '8px 14px', borderRadius: 10, border: 'none', cursor: 'pointer',
              fontFamily: 'Outfit, sans-serif', fontSize: 13, fontWeight: 600,
              background: tab === tab2 ? 'var(--red)' : '#1a1a1a',
              color: tab === tab2 ? '#fff' : 'var(--muted)',
              transition: 'all 0.15s',
            }}>
              {t[tab2]}
            </button>
          ))}
        </div>
        <div className="stack">
          {shown.map(s => (
            <div key={s.id} className="store-item" onClick={() => s.wait ? go('reserve', { mall, store: s }) : null}>
              <div className="store-icon">{s.icon}</div>
              <div className="store-detail">
                <h4>{s.name}</h4>
                <p>{t.level} {s.floor}{s.wait ? ` • ~${s.wait} ${t.minutes}` : ''}</p>
              </div>
              {s.wait > 0 && (
                <button className="store-action" onClick={e => { e.stopPropagation(); go('reserve', { mall, store: s }); }}>
                  {t.queueReserve}
                </button>
              )}
            </div>
          ))}
        </div>
        <div className="spacer" />
        <div className="row" style={{ marginTop: 16 }}>
          <button className="btn btn-primary" style={{ flex: 1 }} onClick={() => go('reserve', { mall, store: STORES[0] })}>{t.queueReserve}</button>
          <button className="btn btn-ghost" style={{ flex: 1 }} onClick={() => go('parking', { mall })}>{t.saveParking}</button>
        </div>
      </div>
    );
  }

  function ReserveScreen({ t, lang, setLang, go, state }) {
    const store = state?.store || STORES[0];
    const mall  = state?.mall  || MALLS[0];
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <div className="nav-bar">
          <button className="nav-back" onClick={() => go('mall-detail', { mall }, true)}>←</button>
          <span className="screen-title">{store.name}</span>
          <div className="nav-spacer" />
        </div>
        <div className="map-ph" style={{ height: 140 }}>
          <span style={{ fontSize: 28 }}>{store.icon}</span>
          <span style={{ fontSize: 13 }}>{t.level} {store.floor}</span>
        </div>
        <div style={{ marginBottom: 24 }}>
          <p style={{ fontSize: 15, marginBottom: 6 }}>⏱ {t.waitAvg}: <span style={{ color: '#fff', fontWeight: 600 }}>{store.wait} {t.minutes}</span></p>
          <p style={{ color: 'var(--muted)', fontSize: 13 }}>4 {t.partiesAhead}</p>
        </div>
        <div style={{ background: 'rgba(255,255,255,0.03)', border: '1px solid var(--border)', borderRadius: 16, padding: 16, marginBottom: 24 }}>
          <p style={{ fontSize: 13, color: 'var(--muted)', marginBottom: 8 }}>Party size</p>
          <div className="row">
            {[1,2,3,4].map(n => (
              <button key={n} style={{
                width: 44, height: 44, borderRadius: 10, border: '1.5px solid',
                borderColor: n === 2 ? 'var(--red)' : 'var(--border)',
                background: n === 2 ? 'var(--red-dim)' : 'transparent',
                color: n === 2 ? 'var(--red)' : 'var(--muted)',
                fontWeight: 600, cursor: 'pointer', fontFamily: 'Outfit, sans-serif',
              }}>
                {n}
              </button>
            ))}
          </div>
        </div>
        <div className="spacer" />
        <div className="stack">
          <button className="btn btn-primary" onClick={() => go('reserved', { mall, store })}>{t.reserveQueue}</button>
          <button className="btn btn-ghost" onClick={() => go('mall-detail', { mall }, true)}>{t.back}</button>
        </div>
      </div>
    );
  }

  function ReservedScreen({ t, lang, setLang, go, state }) {
    const store = state?.store || STORES[0];
    const mall  = state?.mall  || MALLS[0];
    return (
      <div className="screen center" style={{ justifyContent: 'center' }}>
        <LangToggle lang={lang} setLang={setLang} />
        <div className="check-circle" style={{ background: 'var(--red-dim)' }}>🎟️</div>
        <h2 className="title" style={{ textAlign: 'center', marginBottom: 8 }}>{t.queueConfirmed}</h2>
        <p className="subtitle" style={{ textAlign: 'center', marginBottom: 28 }}>{t.queueNote}</p>
        <div className="confirm-card" style={{ width: '100%', marginBottom: 28 }}>
          <h3>{store.name}</h3>
          <div className="big-num">{store.wait}</div>
          <p>{t.yourTurnIn} · <span style={{ color: '#fff' }}>{store.wait} {t.minutes}</span></p>
        </div>
        <div className="stack" style={{ width: '100%' }}>
          <button className="btn btn-primary" onClick={() => go('home')}>{t.explore}</button>
          <button className="btn btn-ghost" onClick={() => go('mall-detail', { mall }, true)}>{t.back}</button>
        </div>
      </div>
    );
  }

  function ParkingScreen({ t, lang, setLang, go, state }) {
    const mall = state?.mall || MALLS[0];
    const [selected, setSelected] = useState(null);
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <div className="nav-bar">
          <button className="nav-back" onClick={() => go('mall-detail', { mall }, true)}>←</button>
          <span className="screen-title">{t.parkingTitle}</span>
          <div className="nav-spacer" />
        </div>
        <div className="map-ph" style={{ height: 160 }}>
          <span className="map-ph-icon">🚗</span>
          <span>Parking Level 2</span>
        </div>
        <p style={{ color: 'var(--muted)', fontSize: 13, marginBottom: 14 }}>{t.pickSpot}</p>
        <div className="parking-grid" style={{ marginBottom: 16 }}>
          {SPOTS.map(s => (
            <button
              key={s}
              className={`spot-btn ${OCCUPIED.includes(s)?'occupied':selected===s?'selected':''}`}
              disabled={OCCUPIED.includes(s)}
              onClick={() => setSelected(s)}
            >{s}</button>
          ))}
        </div>
        {selected && (
          <div className="alert alert-info">
            <p>🚗 {t.level} 2 · {t.zone} {selected}</p>
          </div>
        )}
        <div className="spacer" />
        <button className="btn btn-primary" disabled={!selected} onClick={() => go('parked', { mall, spot: selected })}>
          {t.confirmSpot}
        </button>
      </div>
    );
  }

  function ParkedScreen({ t, lang, setLang, go, state }) {
    const spot = state?.spot || 'A3';
    const mall = state?.mall || MALLS[0];
    return (
      <div className="screen center" style={{ justifyContent: 'center' }}>
        <LangToggle lang={lang} setLang={setLang} />
        <div className="check-circle">✅</div>
        <h2 className="title" style={{ textAlign: 'center', marginBottom: 8 }}>{t.parkingSaved}</h2>
        <p className="subtitle" style={{ textAlign: 'center', marginBottom: 28 }}>{t.parkingNote}</p>
        <div className="confirm-card" style={{ width: '100%', marginBottom: 28 }}>
          <h3>{mall.name}</h3>
          <div className="big-num">{spot}</div>
          <p>{t.level} 2 · {t.zone} {spot}</p>
        </div>
        <div className="stack" style={{ width: '100%' }}>
          <button className="btn btn-primary" onClick={() => go('home')}>{t.navigateBack}</button>
          <button className="btn btn-ghost" onClick={() => go('home')}>{t.explore}</button>
        </div>
      </div>
    );
  }

  function ProfileViewScreen({ t, lang, setLang, go }) {
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <div className="center" style={{ marginTop: 16, marginBottom: 28 }}>
          <div className="avatar">👤</div>
          <h2 style={{ fontSize: 22, fontWeight: 700, marginBottom: 4 }}>John Doe</h2>
          <p style={{ color: 'var(--muted)', fontSize: 14 }}>+66 81 234 5678</p>
        </div>
        <div className="stack" style={{ marginBottom: 16 }}>
          {[
            { icon: '🕐', label: t.history,   sub: '12 visits' },
            { icon: '❤️', label: t.favorites, sub: '5 saved malls' },
          ].map(item => (
            <div key={item.label} className="settings-row">
              <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
                <span style={{ fontSize: 20 }}>{item.icon}</span>
                <div>
                  <div className="settings-label">{item.label}</div>
                  <div className="settings-sub">{item.sub}</div>
                </div>
              </div>
              <span className="settings-arrow">›</span>
            </div>
          ))}
          <div className="settings-row" onClick={() => go('settings')}>
            <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
              <span style={{ fontSize: 20 }}>⚙️</span>
              <div className="settings-label">{t.settings}</div>
            </div>
            <span className="settings-arrow">›</span>
          </div>
        </div>
        <div className="spacer" />
        <button className="btn btn-danger">{t.logout}</button>
        <TabBar active="profile" t={t} go={go} />
      </div>
    );
  }

  function SettingsScreen({ t, lang, setLang, go }) {
    const [notif, setNotif] = useState(true);
    const [dark,  setDark]  = useState(true);
    return (
      <div className="screen">
        <LangToggle lang={lang} setLang={setLang} />
        <div className="nav-bar">
          <button className="nav-back" onClick={() => go('profile-view', null, true)}>←</button>
          <span className="screen-title">{t.settings}</span>
          <div className="nav-spacer" />
        </div>
        <div className="stack">
          <div className="settings-row" onClick={() => setNotif(v => !v)}>
            <div>
              <div className="settings-label">{t.notifications}</div>
              <div className="settings-sub">Queue alerts, parking reminders</div>
            </div>
            <button className={`toggle ${notif?'on':'off'}`} onClick={e => { e.stopPropagation(); setNotif(v=>!v); }} />
          </div>
          <div className="settings-row" onClick={() => setDark(v => !v)}>
            <div>
              <div className="settings-label">{t.darkMode}</div>
              <div className="settings-sub">Always on</div>
            </div>
            <button className={`toggle ${dark?'on':'off'}`} onClick={e => { e.stopPropagation(); setDark(v=>!v); }} />
          </div>
          <div className="settings-row">
            <div>
              <div className="settings-label">{t.language}</div>
              <div className="settings-sub">{lang === 'th' ? 'ภาษาไทย' : 'English'}</div>
            </div>
            <div style={{ display: 'flex', gap: 6 }}>
              {['en','th'].map(l => (
                <button key={l} onClick={() => setLang(l)} style={{
                  padding: '4px 12px', borderRadius: 8, border: 'none', cursor: 'pointer',
                  fontFamily: 'Outfit, sans-serif', fontWeight: 600, fontSize: 13,
                  background: lang === l ? 'var(--red)' : '#1a1a1a',
                  color: lang === l ? '#fff' : 'var(--muted)',
                }}>
                  {l.toUpperCase()}
                </button>
              ))}
            </div>
          </div>
          <div className="settings-row">
            <div>
              <div className="settings-label">{t.version}</div>
              <div className="settings-sub">1.0.0</div>
            </div>
          </div>
        </div>
        <div className="spacer" />
        <button className="btn btn-danger" style={{ marginTop: 16 }}>{t.logout}</button>
      </div>
    );
  }

  /* ─────────── Shared components ─────────── */
  function LangToggle({ lang, setLang }) {
    return (
      <div className="lang-row">
        <button className={`lang-btn ${lang==='th'?'active':''}`} onClick={() => setLang('th')}>TH</button>
        <button className={`lang-btn ${lang==='en'?'active':''}`} onClick={() => setLang('en')}>EN</button>
      </div>
    );
  }

  function TabBar({ active, t, go }) {
    const tabs = [
      { id: 'home',        icon: '🏠', key: 'home'    },
      { id: 'mall-detail', icon: '🗺️', key: 'map'     },
      { id: 'reserved',    icon: '⏰', key: 'queues'  },
      { id: 'parking',     icon: '🚗', key: 'parking' },
      { id: 'profile-view',icon: '👤', key: 'profile' },
    ];
    return (
      <div className="tab-bar" style={{ marginLeft: -24, marginRight: -24, marginBottom: -32 }}>
        {tabs.map(tab => (
          <button key={tab.id} className={`tab-item ${active===tab.key?'active':''}`} onClick={() => go(tab.id)}>
            <span className="tab-icon">{tab.icon}</span>
            <span className="tab-label">{t.tabs[tab.key]}</span>
          </button>
        ))}
      </div>
    );
  }

  /* ─────────── Router ─────────── */
  const SCREEN_MAP = {
    'welcome':      WelcomeScreen,
    'phone':        PhoneScreen,
    'phone-loading':PhoneLoadingScreen,
    'code':         CodeScreen,
    'profile':      ProfileScreen,
    'location':     LocationScreen,
    'home':         HomeScreen,
    'mall-detail':  MallDetailScreen,
    'reserve':      ReserveScreen,
    'reserved':     ReservedScreen,
    'parking':      ParkingScreen,
    'parked':       ParkedScreen,
    'profile-view': ProfileViewScreen,
    'settings':     SettingsScreen,
  };

  function App() {
    const [lang, setLang] = useState('th');
    const [screenId, setScreenId] = useState('welcome');
    const [state, setState] = useState(null);
    const [animClass, setAnimClass] = useState('screen-enter');

    const t = LANG[lang];

    function go(id, newState = null, isBack = false) {
      setAnimClass(isBack ? 'screen-enter-back' : 'screen-enter');
      setScreenId(id);
      setState(newState);
    }

    const Screen = SCREEN_MAP[screenId] || WelcomeScreen;

    return (
      <div className="phone-shell">
        <div className="screen-wrap">
          <div key={screenId} className={animClass} style={{ position: 'absolute', inset: 0 }}>
            <Screen
              t={t} lang={lang} setLang={setLang}
              go={go} state={state}
            />
          </div>
        </div>
      </div>
    );
  }

  ReactDOM.render(<App />, document.getElementById('root'));
</script>
</body>
</html>
