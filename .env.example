# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── LINE LIFF ─────────────────────────────────────────────────
# Each environment uses a different LIFF app from LINE Developers Console.
# Netlify sets the correct value automatically per deploy context.
# For local dev, copy this file to .env.local and fill in the Developing ID.
#
#   Context              LIFF Channel
#   ─────────────────    ─────────────────────────────
#   local / branch       Developing  2009987944-okkfuJvG
#   deploy-preview (PR)  Review      2009987945-LSagpyVK
#   production           Published   2009987946-KuCHw6BO
#
NEXT_PUBLIC_LIFF_ID=<liff-id>
